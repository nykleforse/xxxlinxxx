<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oled_black"
    android:padding="16dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/contactListScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/myId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Your ID: 7F31A2C0" />

            <ImageButton
                android:id="@+id/btnCopyMyId"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Copy ID"
                android:padding="12dp"
                android:scaleType="center"
                android:src="@drawable/ic_copy_24" />
        </LinearLayout>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Disconnected"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/line" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Contacts"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/contactsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <Button
            android:id="@+id/btnOpenAddContact"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_add_contact_fab"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="+"
            android:textColor="@color/text_secondary"
            android:textSize="28sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/addContactScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBackFromAddContact"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:backgroundTint="@color/control"
                android:text="Back"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="New chat"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/addContactIdInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/line"
            android:hint="Contact ID"
            android:imeOptions="actionNext"
            android:inputType="textNoSuggestions|textCapCharacters"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted" />

        <EditText
            android:id="@+id/addContactNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/line"
            android:hint="Local name"
            android:imeOptions="actionDone"
            android:inputType="textCapWords"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted" />

        <Button
            android:id="@+id/btnAddContact"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/control"
            android:text="Add"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chatScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:backgroundTint="@color/control"
                android:text="Back"
                android:textColor="@color/text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/chatTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Alex" />

                <TextView
                    android:id="@+id/chatPeerId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="4C024A76" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnCall"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Call"
                android:padding="12dp"
                android:scaleType="center"
                android:src="@drawable/ic_phone_24" />
        </LinearLayout>

        <RadioGroup
            android:id="@+id/modeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/modeComfy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/text_secondary"
                android:text="comfy"
                android:textColor="@color/text_secondary" />

            <RadioButton
                android:id="@+id/modeBase"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/text_secondary"
                android:checked="true"
                android:text="base"
                android:textColor="@color/text_secondary" />

            <RadioButton
                android:id="@+id/modeXtream"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/text_secondary"
                android:text="Xtream"
                android:textColor="@color/text_secondary" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/callControls"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:text="Accept"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:text="End"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/chatStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="CONNECTED" />

        <TextView
            android:id="@+id/messages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:gravity="bottom"
            android:text=""
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/line"
                android:hint="Message"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <Button
                android:id="@+id/btnSend"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/control"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="^"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/incomingCallScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/oled_black"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Incoming call"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/incomingCallerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="Alex" />

        <TextView
            android:id="@+id/incomingCallerId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            tools:text="4C024A76" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDeclineIncoming"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:text="Decline"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnAcceptIncoming"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:text="Accept"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/outgoingCallScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/oled_black"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Calling"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/outgoingCallName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="Alex" />

        <TextView
            android:id="@+id/outgoingCallCountdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="30"
            android:textColor="@color/text_primary"
            android:textSize="54sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="seconds"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnCancelOutgoingCall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="42dp"
            android:backgroundTint="@color/control"
            android:text="Cancel"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/activeCallScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/oled_black"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/callTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:text="00:00"
            android:textColor="@color/text_primary"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/activeCallName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="Alex" />

        <TextView
            android:id="@+id/activeCallStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Connecting"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginBottom="36dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMuteMic"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:minWidth="0dp"
                android:text="Mic"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnToggleSpeaker"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:minWidth="0dp"
                android:text="Speaker"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnEndActiveCall"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/control"
                android:minWidth="0dp"
                android:text="End"
                android:textColor="@color/text_primary" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
